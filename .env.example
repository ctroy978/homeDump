# Copy this file to .env and adjust for your classroom server.
#   cp .env.example .env

# Admin login (used starting in Phase 4)
ADMIN_PASSWORD=changeme

# Session signing key — use a long random string in production
SECRET_KEY=dev-secret-change-before-classroom-use

# Server bind address and port
HOST=0.0.0.0
PORT=8000

# --- Go live: uncomment and set before students use the app ---
# Address students type into Chrome. QR codes on printed homework use this.
# Use your classroom IP or hostname — not 0.0.0.0 or localhost.
# Examples:
#   PUBLIC_BASE_URL=http://192.168.1.42:8000
#   PUBLIC_BASE_URL=http://my-laptop.local:8000
#PUBLIC_BASE_URL=http://YOUR-CLASSROOM-ADDRESS:8000

# Set true to enable developer-only routes (Phase 3+)
DEBUG=false

# Data directory (relative to project root)
DATA_DIR=data

# Optional explicit database path (default: data/app.db)
# DATABASE_PATH=data/app.db

# Comma-separated list of absence codes that qualify for makeup homework.
# Leave blank to use the built-in defaults.
# ALLOWABLE_ABSENCE_CODES=Excused Absence,Sports-Athletics,Illness,Appointment,Family Emergency,Field Trip/School A,Tardy Excused,In-School Absence,Nurse's Office,School Activity